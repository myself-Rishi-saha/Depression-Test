# =========================================================
# APPLICATION CONFIGURATION
# =========================================================

# Server host binding
# Use 0.0.0.0 for Docker/VPS deployment
HOST=0.0.0.0

# Flask application port
PORT=5000

# Application environment
# Allowed: development | testing | production
FLASK_ENV=development

# Enable Flask debug mode
# true only for local development
FLASK_DEBUG=true

# Flask session/security secret
# Use a long random string (32+ chars)
SECRET_KEY=replace_with_secure_flask_secret_key


# =========================================================
# JWT AUTHENTICATION
# =========================================================

# Secret key used to sign JWT tokens
# Must be long, random, and private
JWT_SECRET_KEY=replace_with_secure_jwt_secret_key

# JWT signing algorithm
# Recommended: HS256
JWT_ALGORITHM=HS256

# JWT access token expiration time in minutes
# Example: 30 = 30 minutes
JWT_ACCESS_TOKEN_EXPIRES=30

# JWT refresh token expiration time in minutes
# Example: 1440 = 1 day
JWT_REFRESH_TOKEN_EXPIRES=1440


# =========================================================
# DATABASE CONFIGURATION
# =========================================================

# MongoDB connection URI
# Local example:
# mongodb://localhost:27017/database_name
MONGO_URI=mongodb://localhost:27017/depression_test_db

# MongoDB database name
DATABASE_NAME=depression_test_db


# =========================================================
# GOOGLE OAUTH
# =========================================================

# Google OAuth client ID
# Obtain from Google Cloud Console
GOOGLE_CLIENT_ID=

# Google OAuth client secret
# Obtain from Google Cloud Console
GOOGLE_CLIENT_SECRET=

# Google OAuth redirect callback URL
GOOGLE_REDIRECT_URI=http://localhost:5000/auth/google/callback


# =========================================================
# EMAIL / SMTP CONFIGURATION
# =========================================================

# SMTP mail server host
# Gmail example: smtp.gmail.com
SMTP_HOST=smtp.gmail.com

# SMTP server port
# Common values:
# 587 = TLS
# 465 = SSL
SMTP_PORT=587

# SMTP login email/username
SMTP_USERNAME=

# SMTP login password or app password
SMTP_PASSWORD=

# Sender email address
# Example:
# no-reply@example.com
MAIL_FROM=


# =========================================================
# AI / ML SERVICES
# =========================================================

# Gemini API key for Google AI services
GEMINI_API_KEY=

# Ollama local server URL
# Default local Ollama instance
OLLAMA_BASE_URL=http://localhost:11434

# Directory path where ML models are stored
ML_MODELS_PATH=ml/models


# =========================================================
# RATE LIMITING
# =========================================================

# Enable/disable API rate limiting
# true | false
RATE_LIMIT_ENABLED=true

# Maximum requests allowed per minute per client
RATE_LIMIT_PER_MINUTE=60


# =========================================================
# LOGGING
# =========================================================

# Logging level
# Allowed:
# DEBUG | INFO | WARNING | ERROR | CRITICAL
LOG_LEVEL=INFO


# =========================================================
# TESTING DATABASE
# =========================================================

# MongoDB URI used during automated tests
TEST_MONGO_URI=mongodb://localhost:27017/test_db

# Database name used during testing
TEST_DATABASE_NAME=test_db