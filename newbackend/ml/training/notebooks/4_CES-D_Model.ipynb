    "def get_spearman_selected_features(X, y, threshold=0.10):\n",
    "    selected_features = []\n",
    "\n",
    "    for column in X.columns:\n",
    "        corr, _ = spearmanr(X[column], y)\n",
    "\n",
    "        if abs(corr) >= threshold:\n",
    "            selected_features.append(column)\n",
    "\n",
    "    return selected_features"
   ]
  },
